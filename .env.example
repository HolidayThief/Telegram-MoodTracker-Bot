# This is an example .env file for the Telegram Mood Tracker Bot.
# Copy this file to .env and fill in your actual values.
# Do NOT commit .env to version control - it contains sensitive credentials.

# Your Telegram Bot Token from @BotFather
# How to get it: 
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot and follow the instructions
#   3. Copy the token provided (looks like: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11)
BOT_TOKEN=your-telegram-bot-token-here